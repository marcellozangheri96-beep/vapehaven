PORT=3000
NODE_ENV=development

# PlazPay Payment Gateway
# Get your API key from merchant.plazpay.com → Channel Management → Payment Gateway
PLAZPAY_API_KEY=your_plazpay_api_key_here
PLAZPAY_API_URL=https://api.plazpay.com/v1

# Resend Email Notifications
# Get your API key from resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
NOTIFICATION_EMAIL=support@vape-roo.com
