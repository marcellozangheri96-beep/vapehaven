PORT=3000
NODE_ENV=development

# NMI Gateway Configuration
NMI_API_URL=https://secure.nmi.com/api/transact.php
NMI_SECURITY_KEY=your_nmi_security_key_here

# Processor Configuration (via NMI Gateway)
# PaymentCloud - Entry level ($0-$30K/month), fees: 3.5-5.0% + $0.30/tx
PROCESSOR_PAYMENTCLOUD_ID=paymentcloud_merchant_id
PROCESSOR_PAYMENTCLOUD_MONTHLY_LIMIT=30000

# DirectPayNet - Scale level ($50K+/month), fees: 2.5-3.8%
PROCESSOR_DIRECTPAYNET_ID=directpaynet_merchant_id
PROCESSOR_DIRECTPAYNET_MONTHLY_LIMIT=80000

# Instabill/EMB - Offshore tank (high cross-border risk), fees: 4.0-6.0%
PROCESSOR_INSTABILL_ID=instabill_merchant_id

# Load Balancing Thresholds (monthly USD)
LOAD_BALANCE_TIER1_MAX=30000
LOAD_BALANCE_TIER2_MAX=80000
